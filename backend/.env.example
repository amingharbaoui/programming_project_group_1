# Voorbeeld-configuratie voor de backend.
# Kopieer dit bestand naar `.env` en vul je eigen waarden in (cp .env.example .env).
# Het echte `.env` staat in .gitignore en wordt nooit gecommit.

# Poort waarop de backend draait
PORT=5000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=jouw_db_gebruiker
DB_PASSWORD=jouw_db_wachtwoord
DB_NAME=stageify

# Geheime sleutel voor het ondertekenen van sessietokens.
# Genereer een eigen waarde met:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=zet-hier-een-eigen-willekeurige-sleutel

# Optioneel: basis-URL voor activatielinks in e-mails
# APP_URL=http://localhost:5173

# Optioneel: SMTP voor uitnodigings- en herinneringsmails (zonder dit worden mails niet verstuurd)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
